{
  "info": {
    "_postman_id": "95cf35db-a2c6-44f7-8cb9-18f4ef3ba6bb",
    "name": "UniSphere Booking Management",
    "description": "Booking workflow API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Request Booking (USER)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resourceId\": {{resourceId}},\n  \"bookingDate\": \"2026-05-02\",\n  \"startTime\": \"09:00:00\",\n  \"endTime\": \"11:00:00\",\n  \"purpose\": \"Project discussion\",\n  \"expectedAttendees\": 15\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/bookings/request",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings",
            "request"
          ]
        }
      }
    },
    {
      "name": "My Bookings (USER)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/bookings/my",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings",
            "my"
          ]
        }
      }
    },
    {
      "name": "All Bookings (ADMIN)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/bookings?status=PENDING&resourceId={{resourceId}}&date=2026-05-02&page=0&size=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings"
          ],
          "query": [
            {
              "key": "status",
              "value": "PENDING"
            },
            {
              "key": "resourceId",
              "value": "{{resourceId}}"
            },
            {
              "key": "date",
              "value": "2026-05-02"
            },
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "Get Booking By ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/bookings/{{bookingId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings",
            "{{bookingId}}"
          ]
        }
      }
    },
    {
      "name": "Approve Booking (ADMIN)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/approve",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings",
            "{{bookingId}}",
            "approve"
          ]
        }
      }
    },
    {
      "name": "Reject Booking (ADMIN)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Resource is reserved for an exam session\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/reject",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings",
            "{{bookingId}}",
            "reject"
          ]
        }
      }
    },
    {
      "name": "Cancel Booking (USER/ADMIN)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings",
            "{{bookingId}}",
            "cancel"
          ]
        }
      }
    },
    {
      "name": "Delete Booking (ADMIN)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/bookings/{{bookingId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings",
            "{{bookingId}}"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8085"
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "resourceId",
      "value": "1"
    },
    {
      "key": "bookingId",
      "value": "1"
    }
  ]
}
